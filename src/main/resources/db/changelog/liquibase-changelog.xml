        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="split-by"/>
            <column name="config_value" value="none"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="format"/>
            <column name="config_value" value="A4"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="customer-copy"/>
            <column name="config_value" value="true"/>
        </insert>

        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="name-mandatory"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="take-away-enabled"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="service-enabled"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="service-cost"/>
            <column name="config_value" value="1.0"/>
        </insert>
    </changeSet>

    <changeSet id="6-app-configurations-required-values" author="Codex">
        <update tableName="app_configurations">
            <column name="config_value" value="&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; viewBox=&quot;0 0 1 1&quot;&gt;&lt;/svg&gt;"/>
            <where>group_name = 'general' AND config_key = 'logo-svg' AND config_value IS NULL</where>
        </update>
    </changeSet>
</databaseChangeLog>

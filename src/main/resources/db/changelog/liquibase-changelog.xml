<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd"
>

    <changeSet id="1" author="Lorenzo Luconi Trombacchi">

        <createTable tableName="users" >
            <column name="username" type="varchar(16)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="password" type="varchar(128)">
                <constraints nullable="false" />
            </column>
            <column name="role" type="enum('admin','user')">
                <constraints nullable="false" />
            </column>

            <column name="created" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="last_update" type="datetime">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="departments">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="name" type="varchar(32)" >
                <constraints nullable="false" />
            </column>

        </createTable>

        <createTable tableName="courses">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="name" type="varchar(32)" >
                <constraints nullable="false" />
            </column>

        </createTable>

        <createTable tableName="products">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="name" type="varchar(255)" >
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="note" type="varchar(255)" >
                <constraints nullable="true" />
            </column>

            <column name="department_id" type="bigint" >
                <constraints referencedTableName="departments" referencedColumnNames="id" foreignKeyName="fk_products_dep" nullable="false" />
            </column>

            <column name="course_id" type="bigint" >
                <constraints referencedTableName="courses" referencedColumnNames="id" foreignKeyName="fk_products_courses" nullable="false" />
            </column>

            <column name="price" type="decimal(6,2)" >
                <constraints nullable="false" />
            </column>

            <column name="sell_locked" type="boolean" defaultValue="false">
                <constraints nullable="false" />
            </column>

            <column name="parent_id" type="bigint" >
                <constraints referencedTableName="products" referencedColumnNames="id" foreignKeyName="fk_products_parent" nullable="true" deleteCascade="true"/>
            </column>

            <column name="created" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="last_update" type="datetime">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="products_quantity">
            <column name="product_id" type="bigint" >
                <constraints referencedTableName="products" referencedColumnNames="id" foreignKeyName="fk_products_quantity" nullable="false" deleteCascade="true"/>
            </column>
            <column name="initial_quantity" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="available_quantity" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="orders">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="customer" type="varchar(128)" />

            <column name="note" type="varchar(255)" />

            <column name="take_away" type="boolean" defaultValue="false" >
                <constraints nullable="false" />
            </column>

            <column name="service_number" type="integer" >
                <constraints nullable="false" />
            </column>

            <column name="service_cost" type="decimal(6,2)">
                <constraints nullable="false" />
            </column>
            <column name="total_amount" type="decimal(6,2)">
                <constraints nullable="false" />
            </column>

            <column name="username" type="varchar(16)" >
                <constraints referencedTableName="users" referencedColumnNames="username" foreignKeyName="fk_orders_users" nullable="false" />
            </column>

            <column name="discount_rate" type="decimal(4,1)" />

            <column name="created" type="datetime">
                <constraints nullable="false"/>
            </column>

            <column name="last_update" type="datetime">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="orders_products">
            <column name="order_id" type="bigint" >
                <constraints primaryKey="true" referencedTableName="orders" referencedColumnNames="id" foreignKeyName="fk_orders_products_order" nullable="false" deleteCascade="true"/>
            </column>
            <column name="product_id" type="bigint" >
                <constraints primaryKey="true" referencedTableName="products" referencedColumnNames="id" foreignKeyName="fk_orders_products_product" nullable="false" />
            </column>
            <column name="price" type="decimal(6,2)" >
                <constraints nullable="false" />
            </column>
            <column name="quantity" type="integer" >
                <constraints nullable="false" />
            </column>
            <column name="note" type="varchar(255)" />
            <column name="idx" type="integer">
                <constraints nullable="true" />
            </column>
        </createTable>

        <createTable tableName="discounts">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="name" type="varchar(32)" >
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="rate" type="decimal(4,1)" >
                <constraints nullable="false" />
            </column>
        </createTable>

        <createTable tableName="monitors">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="name" type="varchar(32)">
                <constraints nullable="false" unique="true"/>
            </column>

        </createTable>

        <createTable tableName="monitors_products">
            <column name="monitor_id" type="bigint" >
                <constraints referencedTableName="monitors" referencedColumnNames="id" foreignKeyName="fk_monitors_products_monitor" nullable="false" deleteCascade="true" primaryKey="true" primaryKeyName="PK_MONITOR_PRODUCT"/>
            </column>
            <column name="product_id" type="bigint" >
                <constraints referencedTableName="products" referencedColumnNames="id" foreignKeyName="fk_monitors_products_product" nullable="false" deleteCascade="true" primaryKey="true" primaryKeyName="PK_MONITOR_PRODUCT"/>
            </column>
            <column name="idx" type="smallint">
                <constraints nullable="false" />
            </column>
        </createTable>


    </changeSet>

    <changeSet id="2-users-auth" author="Codex">
        <modifyDataType tableName="users" columnName="role" newDataType="varchar(16)"/>

        <addColumn tableName="users">
            <column name="name" type="varchar(64)" defaultValue="Administrator">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <update tableName="users">
            <column name="role" value="cashier"/>
            <where>role = 'user'</where>
        </update>
    </changeSet>

    <changeSet id="3-app-configurations" author="Codex">
        <createTable tableName="app_configurations">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="group_name" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="config_key" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="config_value" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>

            <column name="default_value" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="app_configurations"
                             columnNames="group_name, config_key"
                             constraintName="uk_app_configurations_group_key"/>
    </changeSet>

    <changeSet id="4-app-configurations-metadata-in-code" author="Codex">
        <modifyDataType tableName="app_configurations" columnName="config_value" newDataType="longtext"/>

        <dropNotNullConstraint tableName="app_configurations" columnName="config_value" columnDataType="longtext"/>

        <dropColumn tableName="app_configurations" columnName="default_value"/>
    </changeSet>

    <changeSet id="5-app-configurations-initial-values" author="Codex">
        <insert tableName="app_configurations">
            <column name="group_name" value="general"/>
            <column name="config_key" value="name"/>
            <column name="config_value" value="Sagra"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="general"/>
            <column name="config_key" value="date-start"/>
            <column name="config_value" valueComputed="NULL"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="general"/>
            <column name="config_key" value="date-end"/>
            <column name="config_value" valueComputed="NULL"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="general"/>
            <column name="config_key" value="logo-svg"/>
            <column name="config_value" valueComputed="NULL"/>
        </insert>

        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="group-by"/>
            <column name="config_value" value="none"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="format"/>
            <column name="config_value" value="A4"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="print"/>
            <column name="config_key" value="customer-copy"/>
            <column name="config_value" value="true"/>
        </insert>

        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="name-mandatory"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="take-away-available"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="service-enabled"/>
            <column name="config_value" value="true"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="service-cost"/>
            <column name="config_value" value="1.0"/>
        </insert>
        <insert tableName="app_configurations">
            <column name="group_name" value="order"/>
            <column name="config_key" value="payment-credit-card"/>
            <column name="config_value" value="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
